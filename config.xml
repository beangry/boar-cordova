<?xml version='1.0' encoding='utf-8'?>
<widget id="co.beangry.boar" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
	<name>Boar</name>
	<description>Be angry</description>
	<author email="hi@designplox.co" href="https://designplox.com">Ali Zahid</author>
	<content src="index.html"/>
	<access origin="*"/>
	<allow-intent href="http://*/*"/>
	<allow-intent href="https://*/*"/>
	<allow-intent href="tel:*"/>
	<allow-intent href="sms:*"/>
	<allow-intent href="mailto:*"/>
	<allow-intent href="geo:*"/>
	<platform name="android">
		<allow-intent href="market:*"/>
	</platform>
	<platform name="ios">
		<allow-intent href="itms:*"/>
		<allow-intent href="itms-apps:*"/>
	</platform>
	<engine name="ios" spec="~4.3.1"/>
	<engine name="android" spec="~6.0.0"/>
	<plugin name="cordova-plugin-statusbar" spec="~2.2.1"/>
	<plugin name="cordova-plugin-whitelist" spec="1"/>
	<plugin name="cordova-plugin-fcm" spec="~1.1.5"/>
	<preference name="DisallowOverscroll" value="true"/>
	<preference name="StatusBarOverlaysWebView" value="false"/>
	<preference name="StatusBarBackgroundColor" value="#8E8485"/>
	<preference name="StatusBarStyle" value="lightcontent"/>
</widget>
